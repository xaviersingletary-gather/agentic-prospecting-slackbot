# Environment
.env

# Credentials — scoped to avoid catching railway.json / settings JSON.
# Anything that looks like a service-account or secret file stays out.
*credentials*.json
*service-account*.json
*-key.json
gcp-*.json
secret*.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/
.python-version

# Logs
*.log
logs/*.jsonl
logs/account_snapshots/

# macOS
.DS_Store
