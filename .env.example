# Account Research Bot — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── Slack ─────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=                         # xoxb-...
SLACK_APP_TOKEN=                         # xapp-... (Socket Mode)
SLACK_PROSPECTING_CHANNEL=               # e.g. C0XXXXXXX

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                       # Claude Agents SDK (V1+)

# OpenRouter — legacy prototype, kept for backward compat
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ── Research APIs ─────────────────────────────────────────────────────────────
EXA_API_KEY=
APOLLO_API_KEY=

# ── CRM ───────────────────────────────────────────────────────────────────────
HUBSPOT_ACCESS_TOKEN=                    # Phase 7+ — HubSpot private app token

# Salesforce — Phase 9+
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_USERNAME=
SF_PASSWORD=
SF_INSTANCE_URL=                         # e.g. https://yourorg.salesforce.com

# ── Outreach — V2+ ────────────────────────────────────────────────────────────
APOLLO_SEQUENCE_ID=                      # Sequence contacts are enrolled into
HEYREACH_SESSION=                        # Rob's LinkedIn session cookie — rotate when LinkedIn re-auths

# ── Legacy integrations — prototype only ──────────────────────────────────────
CLAY_API_KEY=
GONG_API_KEY=
GONG_API_SECRET=
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_DRIVE_ACCOUNT_PLANS_FOLDER_ID=
DATABASE_URL=                            # Not used in V1 rebuild; Railway PostgreSQL add-on for prototype

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development                  # development | production
LOG_LEVEL=info                           # debug | info | warning | error
MOCK_PERSONAS=false
