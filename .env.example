# =============================================================================
# Gather AI Prospecting Bot — Environment Variables
# Copy this file to .env and fill in real values on the server.
# Never commit .env to git.
# =============================================================================

# LLM
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=                        # e.g. anthropic/claude-3.5-sonnet

# Slack
SLACK_BOT_TOKEN=                         # xoxb-...
SLACK_APP_TOKEN=                         # xapp-... (Socket Mode)
SLACK_PROSPECTING_CHANNEL=               # e.g. #prospecting-bot

# HubSpot
HUBSPOT_ACCESS_TOKEN=                    # Private app token

# Clay
CLAY_API_KEY=

# Gong
GONG_API_KEY=
GONG_API_SECRET=

# Google Drive
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=        # Absolute path to credentials JSON on server

# Database (PostgreSQL — session state)
DATABASE_URL=                            # postgres://user:password@localhost:5432/prospecting_bot

# App
ENVIRONMENT=production                   # production | development
LOG_LEVEL=info                           # debug | info | warning | error
